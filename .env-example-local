LOCAL_SAVE_NODE_MAX_LINES=200
# Max lines permitted in local-save-node-admin editor flow. Default: 800
LOCAL_SAVE_NODE_ADMIN_MAX_LINES=800
# Max lines permitted in local-save-note editor flow. Default: 20
LOCAL_SAVE_NOTE_MAX_LINES=20
