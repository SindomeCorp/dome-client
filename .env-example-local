####################### CORE RUNTIME ########################
# These are the core ENV variables that are needed to get   #
# the app running locally. By default a lot of things are   #
# disabled. You can enable them over time. The production   #
# env file has some better examples of what a prod server   #
# configuration would look like.                            #
#############################################################

# Runtime mode toggle used by templates/debug behavior. Use dev locally. Default: dev
NODE_MODE=dev
# HTTP server listen port for the web client. Use a non-privileged port locally. Default: 80
NODE_PORT=8080
# Winston log verbosity level. Common values: error, warn, info, debug. Default: info
LOG_LEVEL=info
# Express session secret for cookie/session signing. Default: dev-session-secret-change-me
SESSION_SECRET=dev-session-secret-change-me

####################### SOCKET / NETWORK ##################
# Important! If you want to run anywhere besides localhost#
# You'll need to update the NODE_SOCKET_URL               #
###########################################################

# Base URL clients should use for Socket.io (non-SSL). Set to your local host/port. Default: http://localhost:8080
NODE_SOCKET_URL=http://localhost:8080
# Base URL clients should use for Socket.io over SSL. Leave empty when not using local TLS. Default: (empty)
NODE_SOCKET_URL_SSL=
# Trust X-Forwarded-For style proxy headers for client IP detection. Enable only behind a trusted reverse proxy. Default: false
NODE_SOCKET_PROXIED=false

########################## HTTPS ##########################
# If you want SSL, this is where you want to be. Should   #
# work fine with letsencrypt, or others. If left out      #
# we just dont do SSL.                                    #
###########################################################

# HTTPS listen port when SSL is configured. Ignored if SSL_KEY/SSL_CERT are empty. Default: 443
SSL_PORT=443
# Path to SSL private key file. Set for HTTPS deployments; leave empty for HTTP-only local runs. Default: (empty)
SSL_KEY=
# Path to SSL certificate file. Set for HTTPS deployments; leave empty for HTTP-only local runs. Default: (empty)
SSL_CERT=
# Optional SSL private key passphrase, if your key is encrypted. Default: (empty)
SSL_PASSPHRASE=

####################### MOO CONNECTION ####################
# Important! You need to update this section. The guest   #
# command may be fine as the default, or may need updates #
###########################################################

# Display name of the configured game/MOO. Default: Anaconda
MOO_NAME=Anaconda
# Hostname/IP of the backend MOO telnet server. Default: localhost
MOO_HOST=localhost
# Port of the backend MOO telnet server. Default: 5555
MOO_PORT=5555
# Command sent to the MOO when clicking "Connect as a Guest". Default: connect guest
GUEST_CONNECT_COMMAND=connect guest

################## LANDING PAGE / WEBSITE #################
# General config for buttons and assets. Defaults are fine#
# for local dev.                                          #
###########################################################

# Base website URL used for static assets and links. Default: (empty)
WEBSITE_BASE=
# Signup URL for the landing page "Signup Now" button. Leave blank to hide the button. Default: (empty)
WEBSITE_SIGNUP_URL=www.example.com/signup

#################### IDE EDITOR ######################
# Config for the IDE editor lives here. Defaults are #
# fine, but if you want better ctr+click you need to #
# review the MOO-SETUP.md file and implement a way   #
# to handle --open-parent being added to @edit       #
######################################################

# Enables adding --open-parent during IDE ctrl/cmd-click @edit navigation. Default: false
IDE_EDIT_OPEN_PARENT=false
# Enables VMS note prompt/extra note line after @program saves in IDE. Default: false
IDE_VMS_NOTE_ENABLED=false

###########################################################
###########################################################
# Everything after this point is optional or advanced and #
# can be left as is unless you want to implement sidecar  #
# services to support a status service, url-shortener, or #
# you want some Sindome specific stuff.                   #
###########################################################
###########################################################

###################### WEBSITE AUTH #######################
# Optional configuration to allow the client to integrate #
# with a website login flow so you can pass info to the   #
# client about the account / permissions the user has     #
# Completely optional. See the /docs for info on use      #
###########################################################

# Master switch for website-auth login flow on the landing page and /website-login endpoint. Default: false
REMOTEAUTH_ENABLED=false
# Remote auth base URL for website-login authentication bridge (include scheme and optional port). Default: http://localhost
REMOTEAUTH_HOST=http://localhost
# Remote auth path for website-login authentication bridge. Default: /session/authenticate/
REMOTEAUTH_PATH=/session/authenticate/
# Shared secret/token used for remote auth requests. Default: dev-remoteauth-secret-change-me
REMOTEAUTH_REMOTE_SECRET=dev-remoteauth-secret-change-me

################### STATUS SERVICE ###################
# This allows you to integrate with a status service #
# that can provide an icon + overlay in the client   #
# to show the health of the MOO. Requires a sidecar  #
# application to return the data.                    #
# See STATUS-SERVICE.md for more info on how you can #
# implement this if you want.                        #
######################################################

# Full URL (or host) for the external status service endpoint used by /moo/status/ proxy checks.
# If you set only a host like status.example.com, the app assumes https://status.example.com/moo/status/
# Leave empty to hide status UI and disable status polling. Default: (empty)
STATUS_SERVICE_URL=

################## URL SHORTENER #####################
# The allows you to configure the client with a URL  #
# shortener. It needs to have a specific contract    #
# and service which lives elsewhere and the required #
# info for it is in the /docs folder                 #
######################################################

# Master switch for URL shortening feature. Set true to allow shortener usage; false disables and hides option. Default: false
SHORTEN_ENABLED=true
# URL shortener service host used by backend shortening requests. Default: localhost
SHORTEN_HOST=localhost
# URL shortener service port used by backend shortening requests. Default: 5549
SHORTEN_PORT=5549
# URL shortener service request path (POST endpoint). Default: /interface/v1/shorten/
SHORTEN_PATH=/interface/v1/shorten/
# Domain used when constructing returned short URLs shown to users. Default: (empty)
SHORTEN_DOMAIN=
# Minimum URL length eligible for shortening (with internal floor of 25). Default: 50
SHORTEN_MINIMUM=50

################ AUTOCOMPLETE SOURCES ###############
# Configuration for autocomplete, which is disabled #
# by default. When on, we will attempt to complete  #
# commands that are typed in the client. This       #
# requires knowing the type of person who is logged #
# into the game, in order to work properly.         #
#####################################################

# Master switch for backend autocomplete command data. Default: false
AUTOCOMPLETE_ENABLED=false
# Autocomplete source file for player permissions/user type. Default: data/autocomplete/player.txt
AUTOCOMPLETE_P=data/autocomplete/player.txt
# Autocomplete source file for justice permissions/user type. Default: data/autocomplete/justice.txt
AUTOCOMPLETE_J=data/autocomplete/justice.txt
# Autocomplete source file for agent permissions/user type. Default: data/autocomplete/agent.txt
AUTOCOMPLETE_A=data/autocomplete/agent.txt
# Autocomplete source file for creator permissions/user type. Default: data/autocomplete/creator.txt
AUTOCOMPLETE_C=data/autocomplete/creator.txt
# Autocomplete source file for watcher permissions/user type. Default: data/autocomplete/watcher.txt
AUTOCOMPLETE_W=data/autocomplete/watcher.txt
# Autocomplete source file for guest permissions/user type. Default: data/autocomplete/guest.txt
AUTOCOMPLETE_O=data/autocomplete/guest.txt

####################### OTHER ########################
# These are misc ENV variables. The defaults should  #
# suffice for the majority of your purposes.         #
######################################################

# Optional build/version hash override. Leave empty to auto-derive from git when possible. Default: derived from git (or empty on failure)
GIT_HASH=
# Branding label shown in status messages sent by the server. Default: Dome Client
NODE_POWERED_BY=Dome Client

################## SINDOME SPECIFIC ##################
