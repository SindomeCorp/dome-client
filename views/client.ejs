<%
var useMinified = !debugMode;
%>
<% req.bodyClass = 'client'; %>
<div id="browser-client">
  <div id="lineBuffer" class="standardText" aria-live="polite"></div>
  <%- include('partials/mini-controls') %>
  <div class="input-buffer-row">
    <textarea
      data-lpignore="true"
      id="inputBuffer"
      rows="4"
      cols="50"
      inputmode="text"
      autocapitalize="none"
      autocomplete="off"
      autocorrect="off"
    ></textarea>
    <div class="input-history-nav hidden-sm hidden-md hidden-lg" aria-label="Input history controls">
      <button type="button" id="button-input-history-up" class="btn btn-default btn-xs" aria-label="Previous command">▲</button>
      <button type="button" id="button-input-history-down" class="btn btn-default btn-xs" aria-label="Next command">▼</button>
    </div>
  </div>
  <div id="status">
    <i id="perf-buffer-flag" class="hide glyphicon glyphicon-warning-sign" title="Unlimited Scrollback"></i>
    <% if (typeof showStatusService !== "undefined" && showStatusService) { %>
      <a href="<%= statusServiceUrl || '' %>" target="_blank" rel="noopener noreferrer"><span id="gameHealth" class="hidden-xs"><i class="warning-sign warning-sign-warn"></i><i class="globe globe-warn"></i></span></a><span id="statusMsg"></span>
      <div id="gameHealthDetail"></div>
    <% } %>
  </div>
</div>
<%- include('partials/overlays') %>
<%- include('partials/shortcuts-overlay') %>
<%- include('partials/history-search-overlay') %>
<%- include('partials/client-options-overlay') %>
<%- include('partials/disconnect-buttons') %>
  <script defer src="<%=decache('/js/player-client' + (useMinified ? '.min' : '') + '.js')%>"></script>
