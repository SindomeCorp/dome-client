{
  "name": "dome-client.js",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node src/server.js",
    "build": "node src/services/build.js",
    "test": "npm run lint:views && NODE_ENV=test node --experimental-test-module-mocks --import=./test/mock-module.js --test",
     "test:find-slow": "NODE_ENV=test node --experimental-test-module-mocks --import=./test/mock-module.js --test --test-reporter=tap 2>&1 | tee test-output.log | awk -v THRESHOLD=200 -f ./scripts/filter-slow-tap.awk",
    "test:views": "node --test test/views.test.js",
    "coverage": "NODE_ENV=test c8 --check-coverage --lines 80 --functions 80 --statements 80 node --experimental-test-module-mocks --import=./test/mock-module.js --experimental-test-coverage --test",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint .",
    "lint:fix": "ESLINT_USE_FLAT_CONFIG=true eslint . --fix",
    "format:views": "prettier --write \"views/**/*.ejs\"",
    "lint:views": "ejslint \"views/**/*.ejs\""
  },
  "dependencies": {
    "ace-builds": "^1.43.2",
    "autoprefixer": "^10.4.19",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.1",
    "ejs": "^3.1.10",
    "envalid": "^8.1.0",
    "esbuild": "^0.25.9",
    "express": "^5.2.1",
    "express-ejs-layouts": "^2.5.1",
    "express-session": "^1.18.2",
    "less": "^4.4.1",
    "md5": "^2.3.0",
    "morgan": "^1.10.1",
    "postcss": "^8.4.35",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "ua-parser-js": "^1.0.37",
    "winston": "^3.14.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.10"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "c8": "^10.1.3",
    "cssnano": "^7.1.1",
    "ejs-lint": "^2.0.1",
    "eslint": "^9.34.0",
    "expect": "^30.0.5",
    "glob": "^10.4.5",
    "globals": "^16.3.0",
    "jsdom": "^24.0.0",
    "memfs": "^3.x",
    "nock": "^14.0.10",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4"
  },
  "overrides": {
    "mkdirp": {
      "minimist": "^1.2.8"
    },
    "isomorphic-fetch": {
      "node-fetch": "^2.6.7"
    }
  },
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "Firefox ESR",
    "not dead"
  ]
}
